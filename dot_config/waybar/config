{
    //"height": 20, // Waybar height (to be removed for auto height)
    "margin-top": 3,
    "margin-left": 10,
    "margin-bottom": 0,
    "margin-right": 10,
    "spacing": 5, // Gaps between modules (4px)
    "modules-left": [ "cpu", "memory","battery", "backlight", "hyprland/window"],
    "modules-center": ["wlr/workspaces"],
    "modules-right": ["pulseaudio", "network",  "clock", "tray"],
    "wlr/workspaces": {
      "format": "{icon}",
      "on-click": "activate",
      "format-icons": {
        "1": "яДС",
        "2": "яДС",
        "3": "яДС",
        "4": "яДС",
        "5": "яДС",
        "urgent": "яБк",
        "active": "яДС",
        "default": "яДС"
      }
    },
    "hyprland/window": {
        "format": "{}"
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "interval": 1,
        "format": "<span color='#bf616a'>яАЧ </span>{:%H:%M:%S}",
        "format-alt": "<span color='#bf616a'>яБ│ </span>{:%d-%m-%Y}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    },

    "cpu": {
      "interval": 1,
      "format": "яШж {usage}%",
      "max-length": 100,
      "on-click": "",
    },
    "memory": {
        "interval": 30,
        "format": "яШк {}%",
        "format-alt":"яС▓ {used:0.1f}G",
        "max-length": 10,
    },
    "backlight": {
        "device": "DP-1",
        "format": "{icon} {percent}%",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"],
        "on-click": "",
    },
    "network": {
        "format-wifi": "яки {signalStrength}%",
        "format-ethernet": "яЫ┐ wired",
        "format-disconnected": "якй",
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "яАе яКФ {volume}%",
        "format-bluetooth-muted": "якА яКФ",
        "format-muted": "якА",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "bluetoothctl connect FC:58:FA:42:3D:D8"
    },

    "bluetooth": {
        "format": "яКФ {status}",
    },

    "battery": {
      //"bat": "BAT1",
      "adapter": "ADP0",
      "interval": 60,
      "states": {
          "warning": 30,
          "critical": 15
      },
      "on-click": "sh ~/.config/waybar/scripts/power-profiles", 
      "max-length": 20,
      "format": "{icon} {capacity}%",
      "format-warning": "{icon} {capacity}%",
      "format-critical": "{icon} {capacity}%",
      "format-charging": "<span font-family='Font Awesome 6 Free'>яГз</span> {capacity}%",
      "format-plugged": "яЗж  {capacity}%",
      "format-alt": "{icon} {time}",
      "format-full": "яЗж  {capacity}%",
      "format-icons": ["яЙД ", "яЙГ ", "яЙВ ", "яЙБ ", "яЙА "],
    },
}

